---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Link from '../components/BaseLink.astro';
---

<Layout title="Pricing - Togglebase" description="Simple pricing for feature flags. Start free, upgrade when you need more. Coming soon.">
  <Header />
  <main class="pt-14 sm:pt-16 min-h-[calc(100vh-4rem)] flex flex-col">
    <section class="flex-1 flex flex-col items-center justify-center py-16 sm:py-20 md:py-28 px-4 sm:px-6">
      <div class="mx-auto max-w-2xl w-full text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-600 dark:text-brand-400">Pricing</p>
        <h1 class="mt-3 sm:mt-4 text-3xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-4xl md:text-5xl">
          Plans that scale with you
        </h1>
        <p class="mt-4 sm:mt-6 text-base sm:text-lg text-zinc-600 dark:text-zinc-400">
          We’re putting the finishing touches on simple, transparent pricing. Stay tuned.
        </p>
        <div class="mt-10 sm:mt-12 rounded-xl sm:rounded-2xl border-2 border-dashed border-zinc-300 dark:border-zinc-700 bg-zinc-50/50 dark:bg-zinc-900/30 px-4 py-10 sm:px-8 sm:py-12 md:px-12 md:py-16">
          <div class="flex flex-col items-center gap-4">
            <span class="inline-flex items-center gap-2 rounded-full bg-brand-100 dark:bg-brand-900/40 px-4 py-2 text-sm font-medium text-brand-700 dark:text-brand-300">
              <span class="relative flex h-2 w-2">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-brand-500"></span>
              </span>
              Coming soon
            </span>
            <p class="text-zinc-600 dark:text-zinc-400 text-center max-w-sm">
              Pricing plans are coming soon.
            </p>
          </div>
        </div>
        <p class="mt-8 text-sm text-zinc-500 dark:text-zinc-500">
          In the meantime,
          <Link href="/" class="font-medium text-brand-600 dark:text-brand-400 hover:underline">explore Togglebase</Link>
          or
          <Link href="/features" class="font-medium text-brand-600 dark:text-brand-400 hover:underline">see what’s included</Link>.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
