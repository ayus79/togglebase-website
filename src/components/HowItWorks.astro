---
const steps = [
  {
    step: '1',
    title: 'Create flags in the dashboard',
    description: 'Define feature flags for your app. Set rules per environment, add targeting rules, or enable percentage rollouts-all from the UI.',
  },
  {
    step: '2',
    title: 'Integrate with the Python SDK',
    description: 'Install the SDK and add a few lines of code. Evaluate flags in your backend or workers. Changes in the dashboard take effect immediately.',
  },
  {
    step: '3',
    title: 'Ship with confidence',
    description: 'Toggle features on or off, run A/B tests, and roll out gradually-without redeploying. Fix issues or kill switches in seconds.',
  },
];
---

<section id="how-it-works" class="py-16 sm:py-20 md:py-28 bg-zinc-50/50 dark:bg-zinc-900/30">
  <div class="mx-auto max-w-6xl w-full px-4 sm:px-6 lg:px-8 xl:px-8">
    <div class="text-center max-w-2xl mx-auto mb-10 sm:mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-4xl">
        How it works
      </h2>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-zinc-600 dark:text-zinc-400">
        Three steps to feature flags that work the way you do.
      </p>
    </div>
    <div class="space-y-10 sm:space-y-0 sm:grid sm:grid-cols-3 sm:gap-6 md:gap-8 lg:gap-12">
      {steps.map((s) => (
        <div class="relative flex flex-col items-center text-center px-2 sm:px-0">
          <div class="flex h-11 w-11 sm:h-12 sm:w-12 items-center justify-center rounded-xl bg-brand-500 text-white font-bold text-base sm:text-lg shadow-lg shadow-brand-500/25">
            {s.step}
          </div>
          <h3 class="mt-3 sm:mt-4 text-base sm:text-lg font-semibold text-zinc-900 dark:text-white">{s.title}</h3>
          <p class="mt-1.5 sm:mt-2 text-sm sm:text-base text-zinc-600 dark:text-zinc-400">{s.description}</p>
          {s.step !== '3' && (
            <div class="hidden sm:block absolute top-6 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-0.5 bg-gradient-to-r from-brand-300 to-transparent dark:from-brand-600" aria-hidden="true" />
          )}
        </div>
      ))}
    </div>
  </div>
</section>
