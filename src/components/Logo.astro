---
import Link from './BaseLink.astro';

interface Props {
  variant?: 'header' | 'footer';
}

const { variant = 'header' } = Astro.props;
const isFooter = variant === 'footer';
---

<Link
  href="/"
  class="inline-flex items-center gap-2 sm:gap-2.5 text-zinc-900 dark:text-white transition-opacity hover:opacity-90 min-w-0"
  aria-label="Flagswitch home"
>
  <span
    class={`tracking-tight truncate ${
      isFooter ? 'text-lg font-semibold' : 'text-xl sm:text-2xl font-extrabold'
    }`}
  >
    <span class="bg-gradient-to-r from-brand-300 to-brand-500 bg-clip-text text-transparent">
      Flagswitch
    </span>
  </span>
</Link>
