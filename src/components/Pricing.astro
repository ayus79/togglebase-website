---
const tiers = [
  {
    name: 'Starter',
    description: 'For side projects and early-stage apps.',
    price: 'Free',
    period: 'forever',
    cta: 'Get started',
    href: '#',
    features: ['Up to 5 flags', '1 environment', '10k evaluations/month', 'Python SDK', 'Community support'],
    highlighted: false,
  },
  {
    name: 'Pro',
    description: 'For growing teams that ship often.',
    price: '$49',
    period: '/month',
    cta: 'Start free trial',
    href: '#',
    features: ['Unlimited flags', 'Unlimited environments', '500k evaluations/month', 'A/B testing', 'Percentage rollouts', 'Priority support'],
    highlighted: true,
  },
  {
    name: 'Enterprise',
    description: 'For scale and compliance needs.',
    price: 'Custom',
    period: '',
    cta: 'Contact sales',
    href: '#',
    features: ['Everything in Pro', 'Unlimited evaluations', 'SSO & audit logs', 'SLA & dedicated support', 'On-prem option'],
    highlighted: false,
  },
];
---

<section id="pricing" class="py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-4xl">
        Simple pricing
      </h2>
      <p class="mt-4 text-lg text-zinc-600 dark:text-zinc-400">
        Start free. Upgrade when you need more flags, environments, or support.
      </p>
    </div>
    <div class="grid gap-8 lg:grid-cols-3 lg:gap-6">
      {tiers.map((tier) => (
        <article class={`relative flex flex-col rounded-2xl border p-8 sm:p-10 ${
          tier.highlighted
            ? 'border-brand-500 bg-brand-50/50 dark:bg-brand-950/30 shadow-lg shadow-brand-500/10 dark:shadow-brand-500/5 z-10 scale-[1.02]'
            : 'border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50'
        }`}>
          {tier.highlighted && (
            <p class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-500 px-3 py-0.5 text-xs font-semibold text-white">
              Most popular
            </p>
          )}
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white">{tier.name}</h3>
          <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">{tier.description}</p>
          <div class="mt-6 flex items-baseline gap-1">
            <span class="text-3xl font-bold text-zinc-900 dark:text-white">{tier.price}</span>
            {tier.period && <span class="text-zinc-500 dark:text-zinc-400">{tier.period}</span>}
          </div>
          <a
            href={tier.href}
            class={`mt-6 inline-flex justify-center rounded-xl px-4 py-3 text-sm font-semibold transition-colors ${
              tier.highlighted
                ? 'bg-brand-600 text-white hover:bg-brand-700 dark:bg-brand-500 dark:hover:bg-brand-600'
                : 'bg-zinc-900 text-white hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-100'
            }`}
          >
            {tier.cta}
          </a>
          <ul class="mt-8 space-y-3 flex-1">
            {tier.features.map((f) => (
              <li class="flex items-center gap-2 text-sm text-zinc-600 dark:text-zinc-400">
                <span class="text-brand-500">✓</span> {f}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
