---
---

<button
  id="theme-toggle"
  type="button"
  role="switch"
  aria-checked="false"
  aria-label="Toggle dark mode"
  class="relative inline-flex h-9 w-[4.5rem] shrink-0 cursor-pointer rounded-full border-2 border-zinc-200 dark:border-zinc-700 bg-zinc-200 dark:bg-zinc-700 p-1 transition-colors duration-200 hover:border-zinc-300 dark:hover:border-zinc-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 dark:focus-visible:ring-offset-zinc-950"
>
  <!-- Sliding thumb -->
  <span
    class="theme-thumb absolute top-0.5 left-0.5 flex h-7 w-7 items-center justify-center rounded-full bg-white dark:bg-zinc-800 shadow-md ring-0 transition-transform duration-200 ease-out translate-x-0 dark:translate-x-9 text-amber-500 dark:text-amber-400"
    aria-hidden="true"
  >
    <!-- Sun (visible in light mode) -->
    <svg class="h-4 w-4 dark:hidden" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M12 2.25a.75.75 0 01.75.75v2.25a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM7.5 12a4.5 4.5 0 119 0 4.5 4.5 0 01-9 0zM18.894 6.166a.75.75 0 00-1.06-1.06l-1.591 1.59a.75.75 0 101.06 1.061l1.591-1.59zM21.75 12a.75.75 0 01-.75.75h-2.25a.75.75 0 010-1.5H21a.75.75 0 01.75.75zM17.834 18.894a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 10-1.061 1.06l1.59 1.591zM12 18a.75.75 0 01.75.75V21a.75.75 0 01-1.5 0v-2.25A.75.75 0 0112 18zM7.758 17.303a.75.75 0 00-1.061-1.06l-1.591 1.59a.75.75 0 001.06 1.061l1.591-1.59zM6 12a.75.75 0 01-.75.75H3a.75.75 0 010-1.5h2.25A.75.75 0 016 12zM6.697 7.757a.75.75 0 001.06-1.06l-1.59-1.591a.75.75 0 00-1.061 1.06l1.59 1.591z" />
    </svg>
    <!-- Moon (visible in dark mode) -->
    <svg class="h-4 w-4 hidden dark:block" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path fill-rule="evenodd" d="M9.528 1.718a.75.75 0 01.162.819A8.97 8.97 0 009 6a9 9 0 009 9 8.97 8.97 0 003.463-.69.75.75 0 01.981.98 10.503 10.503 0 01-9.694 6.46c-5.799 0-10.5-4.701-10.5-10.5 0-4.368 2.667-8.112 6.46-9.694a.75.75 0 01.818.162z" clip-rule="evenodd" />
    </svg>
  </span>
</button>
