---
import Link from './BaseLink.astro';
---

<section class="relative pt-24 pb-16 sm:pt-28 sm:pb-20 md:pt-36 md:pb-28 overflow-hidden">
  <div class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_80%_60%_at_50%_-20%,rgba(14,165,233,0.15),transparent)] dark:bg-[radial-gradient(ellipse_80%_60%_at_50%_-20%,rgba(14,165,233,0.2),transparent)]" />
  <div class="mx-auto max-w-6xl w-full px-4 sm:px-6 lg:px-8 xl:px-8 text-center">
    <div class="flex flex-wrap items-center justify-center gap-3 mb-8 animate-fade-in">
      <p class="inline-flex items-center gap-2 rounded-full border border-emerald-200 dark:border-emerald-900/60 bg-emerald-50 dark:bg-emerald-950/60 px-4 py-1.5 text-sm font-medium text-emerald-800 dark:text-emerald-300">
        <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" /></svg>
        Open source
      </p>
      <p class="inline-flex items-center gap-2 rounded-full border border-brand-200 dark:border-zinc-800 bg-brand-50 dark:bg-black px-4 py-1.5 text-sm font-medium text-brand-700 dark:text-brand-300">
        <span class="relative flex h-2 w-2"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-brand-400 opacity-75"></span><span class="relative inline-flex h-2 w-2 rounded-full bg-brand-500"></span></span>
        Developer-first • No redeploys
      </p>
    </div>
    <h1 class="text-4xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-5xl md:text-6xl lg:text-7xl animate-slide-up max-w-4xl mx-auto leading-tight px-1">
      Ship features faster.
      <span class="block text-brand-600 dark:text-brand-400">Toggle without redeploying.</span>
    </h1>
    <p class="mt-4 sm:mt-6 text-base sm:text-lg md:text-xl text-zinc-600 dark:text-zinc-400 max-w-2xl mx-auto animate-slide-up px-1" style="animation-delay: 0.1s">
      Free and open source. Feature flags, percentage rollouts, and A/B testing in one platform. Python SDK, multi-environment support, and full control from day one.
    </p>
    <div class="mt-6 sm:mt-8 flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center animate-slide-up px-2 sm:px-0" style="animation-delay: 0.2s">
      <Link href="/pricing" class="inline-flex items-center justify-center rounded-xl bg-zinc-900 dark:bg-white px-5 py-3 sm:px-6 sm:py-3.5 text-sm sm:text-base font-semibold text-white dark:text-zinc-900 shadow-lg hover:bg-zinc-800 dark:hover:bg-zinc-100 transition-all min-h-[44px] sm:min-h-0">
        Get started
      </Link>
      <a href="#code" class="inline-flex items-center justify-center rounded-xl border-2 border-zinc-300 dark:border-zinc-600 px-5 py-3 sm:px-6 sm:py-3.5 text-sm sm:text-base font-semibold text-zinc-900 dark:text-white hover:border-zinc-400 dark:hover:border-zinc-500 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-all min-h-[44px] sm:min-h-0">
        View code example
      </a>
    </div>
  </div>
</section>
