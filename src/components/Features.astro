---
const features = [
  {
    title: 'Remote toggles',
    description: 'Turn features on or off from the dashboard. No code deploy required. Change behavior in seconds.',
    icon: '🔀',
  },
  {
    title: 'Percentage rollouts',
    description: 'Release to 5%, 25%, or 100% of users. Gradual rollouts reduce risk and catch issues early.',
    icon: '📊',
  },
  {
    title: 'A/B testing',
    description: 'Run experiments and compare variants. Data-driven decisions with built-in metrics and segments.',
    icon: '🧪',
  },
  {
    title: 'Multi-environment',
    description: 'Separate dev, staging, and production. Each environment has its own flag state and overrides.',
    icon: '🌍',
  },
  {
    title: 'Python SDK',
    description: 'Integrate in minutes with our first-class Python client. Type-safe, async support, and local caching.',
    icon: '🐍',
  },
  {
    title: 'No redeploys',
    description: 'Control feature behavior at runtime. Fix issues or kill switches without touching your pipeline.',
    icon: '⚡',
  },
];
---

<section id="features" class="py-16 sm:py-20 md:py-28 bg-zinc-50/50 dark:bg-zinc-900/30">
  <div class="mx-auto max-w-6xl w-full px-4 sm:px-6 lg:px-8 xl:px-8">
    <div class="text-center max-w-2xl mx-auto mb-10 sm:mb-16">
      <h2 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-white sm:text-4xl">
        Built for how you ship
      </h2>
      <p class="mt-3 sm:mt-4 text-base sm:text-lg text-zinc-600 dark:text-zinc-400 px-1">
        Everything you need to release confidently: toggles, rollouts, experiments, and environments without slowing down.
      </p>
    </div>
    <div class="grid gap-6 sm:gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <article class="group rounded-2xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-5 sm:p-6 md:p-8 shadow-sm hover:shadow-md hover:border-brand-200 dark:hover:border-brand-800 transition-all duration-200">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-lg font-semibold text-zinc-900 dark:text-white">{f.title}</h3>
          <p class="mt-2 text-zinc-600 dark:text-zinc-400">{f.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
